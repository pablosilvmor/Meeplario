rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Deny-All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---

    function isValidItem(data) {
      return data.keys().hasAll(['name', 'sectorId', 'currentStock', 'minStock', 'idealStock', 'unit']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.sectorId is string &&
             data.currentStock is number && data.currentStock >= 0 &&
             data.minStock is number && data.minStock >= 0 &&
             data.idealStock is number && data.idealStock >= 0 &&
             data.unit is string && data.unit.size() <= 10;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'meeplariojogos@gmail.com' || 
        request.auth.token.email == 'pablo.silvmor@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    function isApproved() {
      return isAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role', 'approved', 'allowedSectors']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['admin', 'chef'] &&
             data.approved is bool &&
             data.allowedSectors is list &&
             (isAdmin() || (data.approved == false && data.role == 'chef'));
    }

    function isValidLog(data) {
      return data.keys().hasAll(['itemId', 'itemName', 'userName', 'userId', 'type', 'amount', 'timestamp']) &&
             data.itemId is string && data.itemName is string &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time;
    }

    // --- Collection Rules ---

    match /sectors/{sectorId} {
      allow read: if isSignedIn() && isApproved();
      allow create, update, delete: if isAdmin();
    }

    match /items/{itemId} {
      allow get, list: if isSignedIn() && isApproved();
      allow create, delete: if isAdmin();
      allow update: if isSignedIn() && isApproved() && (
        // Stock update action
        (incoming().diff(existing()).affectedKeys().hasOnly(['currentStock', 'updatedAt', 'lastUpdatedBy']) &&
         incoming().currentStock is number && incoming().currentStock >= 0 &&
         incoming().updatedAt == request.time) ||
        // Full update (Admin only)
        isAdmin()
      );
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && (request.auth.uid == userId) && isValidUser(incoming());
      allow update: if isAdmin() || (isSignedIn() && (request.auth.uid == userId) && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['name']));
    }

    match /history/{logId} {
      allow list: if isSignedIn() && isApproved();
      allow create: if isSignedIn() && isApproved() && isValidLog(incoming());
    }
  }
}
